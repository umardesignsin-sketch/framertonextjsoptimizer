{
  "name": "framer-to-nextjs",
  "version": "0.1.0",
  "description": "Convert any published Framer site into a real Next.js project or an optimized static bundle — from the command line. No Framer login, no plugin, just a URL.",
  "bin": {
    "framer-to-nextjs": "dist/index.js"
  },
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "framer",
    "nextjs",
    "framer-to-nextjs",
    "framer-to-html",
    "convert",
    "export",
    "static-site",
    "cli"
  ],
  "homepage": "https://framertonextjs.com",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5"
  }
}
