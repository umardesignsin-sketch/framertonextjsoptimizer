// CMS platform — data model.
// Phase 1: multi-tenant foundation (User, Site, Deployment). CMS content
// entities (Page, BlogPost, Collection, Media, Nav, Forms, Seo, Settings,
// Domain) are added in their respective phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SiteStatus {
  draft
  converting
  ready
  published
  error
}

enum DeployStatus {
  queued
  building
  ready
  error
}

/// A platform user. `id` is the Supabase Auth user UUID; the password and
/// email verification live in Supabase's auth schema. This row is upserted on
/// first authenticated request so app data (Sites) can FK to it.
model User {
  id        String   @id
  email     String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
}

/// A converted website owned by a user. Root of all per-site CMS data, so
/// every CMS record is isolated by `siteId` (+ ownership checks in the app).
model Site {
  id         String     @id @default(cuid())
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  framerUrl  String
  /// "hybrid" (default converter) or "nextjs" (pure Next.js export).
  outputKind String     @default("hybrid")
  /// Reference to the imported design bundle in Blob (the converter output job id).
  themeRef   String?
  status     SiteStatus @default(draft)
  /// Netlify build hook URL used by "Publish" to trigger a rebuild.
  buildHook  String?
  /// Visual-editor unpublished draft: an EditorEdit[] captured in the editor,
  /// applied to the bundle + pushed live on Publish.
  draftEdits Json?
  /// Studio (Framer-style canvas) page tree — a DesignDoc of JSON component
  /// trees, edited as blocks on artboards. Independent of the converted bundle.
  designTree Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  deployments Deployment[]

  @@index([ownerId])
  @@index([status])
}

/// A blog post published on the marketing site (founders panel authors these).
/// Content is Markdown, rendered to HTML at request time.
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  /// Markdown body.
  content     String
  coverImage  String?
  tags        String[]  @default([])
  /// "draft" or "published".
  status      String    @default("draft")
  authorName  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
}

/// A deployment of a site to a host (Netlify first).
model Deployment {
  id              String       @id @default(cuid())
  siteId          String
  site            Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  provider        String       @default("netlify")
  status          DeployStatus @default(queued)
  netlifyDeployId String?
  url             String?
  log             String?
  /// Provider-side target for redeploys: Netlify site id / Vercel project name.
  externalId      String?
  /// User's deploy token, AES-256-GCM encrypted (lib/crypto.ts). Stored only
  /// when the user opts in ("save for AI edits"); enables the AI editor to
  /// push changes back to the same live site.
  tokenEnc        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([siteId, createdAt])
}

/// First-touch signup attribution, keyed by the Supabase auth user id.
/// Captured once at first sign-in (auth callback) — country from the CDN geo
/// header, source/referrer/UTM from a first-touch cookie set on landing.
model SignupMeta {
  userId      String   @id
  country     String?
  source      String?
  medium      String?
  campaign    String?
  referrer    String?
  landingPath String?
  /// Parsed from the User-Agent header at signup: "desktop" | "mobile" | "tablet".
  device      String?
  /// e.g. "Chrome", "Safari", "Firefox", "Edge". Best-effort UA sniffing —
  /// browsers that deliberately present as Chrome for compatibility (Arc,
  /// Brave in some configs) aren't distinguishable from the UA string alone.
  browser     String?
  /// e.g. "Windows", "macOS", "iOS", "Android", "Linux".
  os          String?
  createdAt   DateTime @default(now())
}

/// "Need help?" badge submissions (site-wide, bottom-right). Always stored
/// here regardless of whether email delivery is configured (RESEND_API_KEY)
/// — the DB row is the durable record; email is a best-effort notification
/// on top of it, not the source of truth.
model ContactMessage {
  id        String   @id @default(cuid())
  email     String
  message   String
  /// Page the badge was opened from, for context (e.g. "/dashboard").
  page      String?
  /// True once an email notification was successfully sent for this row.
  emailed   Boolean  @default(false)
  createdAt DateTime @default(now())
}
