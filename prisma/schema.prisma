// CMS platform — data model.
// Phase 1: multi-tenant foundation (User, Site, Deployment). CMS content
// entities (Page, BlogPost, Collection, Media, Nav, Forms, Seo, Settings,
// Domain) are added in their respective phases.
//
// CmsConnection/Collection/CollectionItem (below) are a one-way import of a
// Framer project's own CMS via Framer's Server API (framer-api) — read-only
// mirror; editing happens only in our admin panel, never written back to Framer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SiteStatus {
  draft
  converting
  ready
  published
  error
}

enum DeployStatus {
  queued
  building
  ready
  error
}

/// A platform user. `id` mirrors the Clerk user id (synced via webhook).
model User {
  id        String   @id
  email     String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
}

/// A converted website owned by a user. Root of all per-site CMS data, so
/// every CMS record is isolated by `siteId` (+ ownership checks in the app).
model Site {
  id         String     @id @default(cuid())
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  framerUrl  String
  /// Reference to the imported design bundle in Blob (the converter output).
  themeRef   String?
  status     SiteStatus @default(draft)
  /// Netlify build hook URL used by "Publish" to trigger a rebuild.
  buildHook  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  deployments Deployment[]
  cms         CmsConnection?

  @@index([ownerId])
  @@index([status])
}

/// A deployment of a site to a host (Netlify first).
model Deployment {
  id              String       @id @default(cuid())
  siteId          String
  site            Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  provider        String       @default("netlify")
  status          DeployStatus @default(queued)
  netlifyDeployId String?
  url             String?
  log             String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([siteId, createdAt])
}

enum CmsSyncStatus {
  idle
  syncing
  synced
  error
}

/// A one-way link to a Framer project's CMS via Framer's Server API
/// (https://www.framer.com/developers/server-api-quick-start). The API key is
/// encrypted at rest (lib/crypto.ts) and never sent to the client.
model CmsConnection {
  id           String        @id @default(cuid())
  siteId       String        @unique
  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  /// Framer project URL, e.g. https://framer.com/projects/Sites--aabbccddeeff
  projectUrl   String
  apiKeyEnc    String
  status       CmsSyncStatus @default(idle)
  error        String?
  lastSyncedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  collections Collection[]
}

/// A CMS collection mirrored from Framer (read-only snapshot; re-synced on demand).
model Collection {
  id           String        @id @default(cuid())
  connectionId String
  connection   CmsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  /// Framer's own collection id.
  framerId     String
  name         String
  /// Framer field definitions ({id, name, type}[]) as returned by the Server API.
  fields       Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items CollectionItem[]

  @@unique([connectionId, framerId])
  @@index([connectionId])
}

/// One item within a mirrored collection. Edits here stay local — never
/// written back to the source Framer project.
model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  /// Framer's own item id.
  framerId     String
  slug         String?
  /// Field values keyed by Framer field id, as returned by the Server API.
  data         Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([collectionId, framerId])
  @@index([collectionId])
}
