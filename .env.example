# ─── CMS platform (Phase 1) ─────────────────────────────────────────────────
# Postgres (Neon/Supabase). DATABASE_URL = pooled, DIRECT_URL = direct (migrations).
DATABASE_URL=
DIRECT_URL=

# Clerk auth (https://dashboard.clerk.com → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Netlify (publish pipeline / build hooks)
NETLIFY_API_TOKEN=

# Auth.js session signing secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Visual editor: encrypts saved deploy tokens at rest (same generator as above).
ENCRYPTION_KEY=

# ─── Supabase auth ──────────────────────────────────────────────────────────
# From your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Existing converter ─────────────────────────────────────────────────────
# Job/bundle storage. Preferred: Cloudflare R2 (S3-compatible, ZERO egress
# fees — the Vercel Blob free tier's 10GB/month transfer cap once paused the
# store and broke previews). When all four R2_* vars are set, R2 is used;
# otherwise falls back to Vercel Blob below.
# Cloudflare dashboard → R2 → create bucket → Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Vercel Blob (fallback). Set automatically by a connected store.
BLOB_READ_WRITE_TOKEN=
# Google PageSpeed (Lighthouse comparison)
PAGESPEED_API_KEY=
# Single-password admin gate (legacy; superseded by Clerk in the dashboard)
ADMIN_PASSWORD=
